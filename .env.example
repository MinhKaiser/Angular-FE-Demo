# Environment Configuration
# This file should NOT be committed to git
# Copy from .env.example and update with your values

# API Configuration
NG_APP_API_URL=https://dummyjson.com
NG_APP_API_TIMEOUT=30000

# Application
NG_APP_ENVIRONMENT=development
NG_APP_DEBUG=true

# Feature Flags (for future use)
NG_APP_ENABLE_ANALYTICS=false
NG_APP_ENABLE_SENTRY=false

# Optional: Auth Config (if needed for future OAuth/external auth)
# NG_APP_AUTH_PROVIDER=dummyjson
# NG_APP_AUTH_CLIENT_ID=your_client_id
# NG_APP_AUTH_CLIENT_SECRET=your_client_secret
