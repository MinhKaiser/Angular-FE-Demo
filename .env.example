# Environment Configuration Example
# Commit this file as documentation for local configuration.
# Copy it to .env for local-only overrides when a build pipeline supports env injection.
# Do not put real secrets in Angular/browser environment files.

# API Configuration
NG_APP_API_URL=https://dummyjson.com
NG_APP_API_TIMEOUT=30000

# Application
NG_APP_ENVIRONMENT=development
NG_APP_DEBUG=true

# Feature Flags (for future use)
NG_APP_ENABLE_ANALYTICS=false
NG_APP_ENABLE_SENTRY=false

# Optional public auth metadata only. Never store client secrets in frontend code.
# NG_APP_AUTH_PROVIDER=dummyjson
# NG_APP_AUTH_CLIENT_ID=your_client_id
